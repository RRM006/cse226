#!/bin/bash
# NSU Audit Core - Interactive Web Launcher
#
# Usage:
#   ./web              - Interactive menu (recommended)
#
# Note: The old positional-argument interface (./web local, ./web local remote)
# is now handled by the interactive menu inside web_launcher.py.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Detect Python executable (use venv if available)
if [ -d "$SCRIPT_DIR/.venv" ]; then
    PYTHON="$SCRIPT_DIR/.venv/bin/python"
else
    PYTHON="python"
fi

exec "$PYTHON" "$SCRIPT_DIR/web_launcher.py"
