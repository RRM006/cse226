#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
MCP_DIR="$SCRIPT_DIR/mcp"
VENV_PATH="$MCP_DIR/venv"

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

print_error() {
    echo -e "${RED}Error: $1${NC}"
}

print_info() {
    echo -e "${YELLOW}$1${NC}"
}

print_success() {
    echo -e "${GREEN}$1${NC}"
}

show_usage() {
    echo "Usage:"
    echo "  mcp offline   →  offline mode (local Phase 1 engine)"
    echo "  mcp remote   →  remote mode (Railway backend)"
    echo "  mcp reauth   →  force Google re-login"
}

if [ -z "$1" ]; then
    show_usage
    exit 1
fi

COMMAND="$1"

if [ ! -d "$VENV_PATH" ]; then
    print_info "Creating virtual environment at mcp/venv..."
    python3 -m venv "$VENV_PATH"
    print_success "Virtual environment created."
fi

source "$VENV_PATH/bin/activate"
cd "$MCP_DIR"

if [ -f "requirements.txt" ]; then
    pip install -r requirements.txt --quiet 2>/dev/null
fi

case "$COMMAND" in
    offline)
        print_info "NSU Audit MCP — OFFLINE mode starting..."
        python mcp_server.py
        ;;
    remote)
        TOKEN_FILE="$HOME/.nsu_mcp/api_token.txt"
        if [ -f "$TOKEN_FILE" ] && [ -s "$TOKEN_FILE" ]; then
            print_success "Token found."
        else
            print_error "No API token found."
            printf "Paste your Railway API token: "
            read -s API_TOKEN
            echo
            mkdir -p "$HOME/.nsu_mcp"
            echo "$API_TOKEN" > "$TOKEN_FILE"
            chmod 600 "$TOKEN_FILE"
            print_success "Token saved."
        fi
        print_info "NSU Audit MCP — REMOTE mode starting..."
        python mcp_server.py --remote
        ;;
    reauth)
        print_info "Forcing Google re-authentication..."
        python mcp_server.py --reauth
        ;;
    *)
        show_usage
        exit 1
        ;;
esac
