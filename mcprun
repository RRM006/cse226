#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
MCP_DIR="$SCRIPT_DIR/mcp"
VENV_PATH="$MCP_DIR/venv"
BACKEND_DIR="$SCRIPT_DIR/backend"
FRONTEND_DIR="$SCRIPT_DIR/frontend"

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

print_error() {
    echo -e "${RED}Error: $1${NC}"
}

print_info() {
    echo -e "${YELLOW}$1${NC}"
}

print_success() {
    echo -e "${GREEN}$1${NC}"
}

show_usage() {
    echo "Usage:"
    echo "  mcp web          →  Start all services (backend + frontend + MCP)"
    echo "  mcp webstop     →  Stop all services (backend + frontend + MCP)"
    echo "  mcp local       →  Start MCP server only (local backend)"
    echo "  mcp local remote →  Start MCP server only (Railway backend)"
    echo "  mcp status       →  Check if services are running"
    echo "  mcp stop         →  Stop MCP server only"
    echo "  mcp reauth       →  Force Google re-login"
}

get_mcp_pid() {
    ps aux | grep "python.*mcp_server.py" | grep -v grep | awk '{print $2}' | head -1
}

get_backend_pid() {
    ps aux | grep "uvicorn.*main:app" | grep -v grep | awk '{print $2}' | head -1
}

get_frontend_pid() {
    ps aux | grep "vite" | grep -v grep | awk '{print $2}' | head -1
}

check_port() {
    local port=$1
    if netstat -tuln 2>/dev/null | grep -q ":$port " || ss -tuln 2>/dev/null | grep -q ":$port "; then
        return 0
    fi
    return 1
}

if [ -z "$1" ]; then
    show_usage
    exit 1
fi

COMMAND="$1"
MODE="$2"

case "$COMMAND" in
    web)
        print_info "Starting NSU Audit Core - Local Development..."
        echo ""
        
        # Check if MCP already running
        MCP_PID=$(get_mcp_pid)
        if [ -n "$MCP_PID" ]; then
            print_info "MCP server is already running (PID: $MCP_PID)"
        fi
        
        # Check if backend already running
        BACKEND_PID=$(get_backend_pid)
        if [ -n "$BACKEND_PID" ]; then
            print_info "Backend is already running (PID: $BACKEND_PID)"
        elif check_port 8000; then
            print_info "Backend is already running on port 8000"
        else
            print_info "Starting backend (FastAPI) on port 8000..."
            cd "$BACKEND_DIR"
            PYTHONPATH="$BACKEND_DIR" nohup python -m uvicorn main:app --reload --port 8000 > /dev/null 2>&1 &
            sleep 2
            print_success "Backend started."
        fi
        
        # Check if frontend already running
        FRONTEND_PID=$(get_frontend_pid)
        if [ -n "$FRONTEND_PID" ]; then
            print_info "Frontend is already running (PID: $FRONTEND_PID)"
        elif check_port 5173; then
            print_info "Frontend is already running on port 5173"
        else
            print_info "Starting frontend (Vite) on port 5173..."
            cd "$FRONTEND_DIR"
            nohup npm run dev > /dev/null 2>&1 &
            sleep 3
            print_success "Frontend started."
        fi
        
        # Start MCP if not running
        if [ -z "$MCP_PID" ]; then
            if [ ! -d "$VENV_PATH" ]; then
                print_info "Creating virtual environment at mcp/venv..."
                python3 -m venv "$VENV_PATH"
                print_success "Virtual environment created."
            fi

            source "$VENV_PATH/bin/activate"
            cd "$MCP_DIR"

            if [ -f "requirements.txt" ]; then
                pip install -r requirements.txt --quiet 2>/dev/null
            fi

            print_info "Starting MCP server (local backend)..."
            nohup python mcp_server.py > /dev/null 2>&1 &
            sleep 2
            print_success "MCP server started."
        fi
        
        echo ""
        echo "============================================================"
        print_success "✅ All services running!"
        echo "============================================================"
        echo "   Backend:    http://localhost:8000"
        echo "   Frontend:  http://localhost:5173"
        echo "   MCP:       Running (local backend)"
        echo ""
        echo "Open in browser:"
        echo "   Frontend: http://localhost:5173"
        echo "   API Docs: http://localhost:8000/docs"
        echo "============================================================"
        ;;
    
    webstop)
        print_info "Stopping all services..."
        
        # Stop MCP
        MCP_PID=$(get_mcp_pid)
        if [ -n "$MCP_PID" ]; then
            kill "$MCP_PID" 2>/dev/null
            print_success "MCP server stopped."
        fi
        
        # Stop backend
        BACKEND_PID=$(get_backend_pid)
        if [ -n "$BACKEND_PID" ]; then
            kill "$BACKEND_PID" 2>/dev/null
            print_success "Backend stopped."
        fi
        
        # Stop frontend
        FRONTEND_PID=$(get_frontend_pid)
        if [ -n "$FRONTEND_PID" ]; then
            kill "$FRONTEND_PID" 2>/dev/null
            print_success "Frontend stopped."
        fi
        
        # Also kill any process on ports 8000 and 5173
        fuser -k 8000/tcp 2>/dev/null
        fuser -k 5173/tcp 2>/dev/null
        
        echo ""
        print_success "✅ All services stopped."
        ;;
    
    local)
        # Check if already running
        PID=$(get_mcp_pid)
        if [ -n "$PID" ]; then
            print_success "MCP server is already running (PID: $PID)"
            exit 0
        fi
        
        if [ ! -d "$VENV_PATH" ]; then
            print_info "Creating virtual environment at mcp/venv..."
            python3 -m venv "$VENV_PATH"
            print_success "Virtual environment created."
        fi

        source "$VENV_PATH/bin/activate"
        cd "$MCP_DIR"

        if [ -f "requirements.txt" ]; then
            pip install -r requirements.txt --quiet 2>/dev/null
        fi

        if [ "$MODE" = "remote" ]; then
            TOKEN_FILE="$HOME/.nsu_mcp/api_token.txt"
            if [ -f "$TOKEN_FILE" ] && [ -s "$TOKEN_FILE" ]; then
                print_success "Token found."
            else
                print_error "No API token found."
                printf "Paste your Railway API token: "
                read -s API_TOKEN
                echo
                mkdir -p "$HOME/.nsu_mcp"
                echo "$API_TOKEN" > "$TOKEN_FILE"
                chmod 600 "$TOKEN_FILE"
                print_success "Token saved."
            fi
            print_info "NSU Audit MCP — REMOTE mode starting (Railway backend)..."
            python mcp_server.py --remote
        else
            print_info "NSU Audit MCP — LOCAL mode starting (local backend: http://localhost:8000)..."
            python mcp_server.py
        fi
        ;;
    
    status)
        echo "Checking services..."
        echo ""
        
        # Check backend
        BACKEND_PID=$(get_backend_pid)
        if [ -n "$BACKEND_PID" ]; then
            print_success "Backend:    Running (PID: $BACKEND_PID, port 8000)"
        elif check_port 8000; then
            print_success "Backend:    Running (port 8000)"
        else
            print_error "Backend:    Not running"
        fi
        
        # Check frontend
        FRONTEND_PID=$(get_frontend_pid)
        if [ -n "$FRONTEND_PID" ]; then
            print_success "Frontend:   Running (PID: $FRONTEND_PID, port 5173)"
        elif check_port 5173; then
            print_success "Frontend:   Running (port 5173)"
        else
            print_error "Frontend:   Not running"
        fi
        
        # Check MCP
        MCP_PID=$(get_mcp_pid)
        if [ -n "$MCP_PID" ]; then
            print_success "MCP:        Running (PID: $MCP_PID)"
        else
            print_error "MCP:        Not running"
        fi
        ;;
    
    stop)
        PID=$(get_mcp_pid)
        if [ -n "$PID" ]; then
            print_info "Stopping MCP server (PID: $PID)..."
            kill "$PID"
            print_success "MCP server stopped."
        else
            print_error "MCP server is not running."
        fi
        ;;
    
    reauth)
        if [ ! -d "$VENV_PATH" ]; then
            print_info "Creating virtual environment at mcp/venv..."
            python3 -m venv "$VENV_PATH"
            print_success "Virtual environment created."
        fi

        source "$VENV_PATH/bin/activate"
        cd "$MCP_DIR"

        if [ -f "requirements.txt" ]; then
            pip install -r requirements.txt --quiet 2>/dev/null
        fi
        
        print_info "Forcing Google re-authentication..."
        python mcp_server.py --reauth
        ;;
    
    offline)
        COMMAND="local" MODE="" "$0" local
        ;;
    
    remote)
        COMMAND="local" MODE="remote" "$0" local remote
        ;;
    
    *)
        show_usage
        exit 1
        ;;
esac
