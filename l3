#!/usr/bin/env python3
"""
Level 3 Audit CLI
Usage: l3 [csv_file] [program]
"""
import sys
import os

project_root = os.getcwd()
sys.path.insert(0, project_root)

from cli.credentials import is_logged_in

if not is_logged_in():
    print("You must be logged in to run audits.")
    print("Run: login")
    sys.exit(1)

import argparse
from pathlib import Path

PROJECT_ROOT = Path(os.getcwd())

def main():
    parser = argparse.ArgumentParser(description="Level 3 Audit")
    parser.add_argument("csv", nargs="?", help="Path to CSV file")
    parser.add_argument("program", nargs="?", help="Program (BSCSE, BSEEE, LLB)")
    args = parser.parse_args()
    
    csv_path = args.csv
    program = args.program
    
    if not csv_path:
        csv_path = input("Enter CSV file path: ").strip()
    
    if not program:
        program = input("Enter program (BSCSE, BSEEE, or LLB): ").strip().upper()
    
    csv_path_obj = Path(csv_path)
    if not csv_path_obj.is_absolute():
        csv_path_obj = Path.cwd() / csv_path
    
    if not csv_path_obj.exists():
        print(f"File not found: {csv_path_obj}")
        sys.exit(1)
    
    knowledge_path = PROJECT_ROOT / "program_knowledge" / f"program_knowledge_{program}.md"
    
    if not knowledge_path.exists():
        print(f"Knowledge file not found: {knowledge_path}")
        sys.exit(1)
    
    print(f"\n=== Level 3 Audit for {program} ===\n")
    
    from src.level3_audit_engine import main as level3_main
    
    sys.argv = ["level3_audit_engine", str(csv_path_obj), str(knowledge_path)]
    level3_main()


if __name__ == "__main__":
    main()
