#!/bin/bash
# MCP server control script
#
# Usage:
#   mcp local       - Start MCP server in offline mode (local Phase 1 engine)
#   mcp local remote - Start MCP server in remote mode (Railway backend)
#   mcp stop        - Stop MCP server
#   mcp status      - Check if MCP server is running

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PROJECT_ROOT="$SCRIPT_DIR"

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

print_error() {
    echo -e "${RED}Error: $1${NC}"
}

print_info() {
    echo -e "${YELLOW}$1${NC}"
}

print_success() {
    echo -e "${GREEN}$1${NC}"
}

show_usage() {
    echo "Usage:"
    echo "  mcp local        - Start MCP server (offline mode)"
    echo "  mcp local remote - Start MCP server (remote mode)"
    echo "  mcp stop         - Stop MCP server"
    echo "  mcp status       - Check MCP server status"
}

get_mcp_pid() {
    ps aux | grep "python.*mcp_server.py" | grep -v grep | awk '{print $2}' | head -1
}

find_python() {
    if [ -x "$SCRIPT_DIR/../.venv/bin/python" ]; then
        echo "$SCRIPT_DIR/../.venv/bin/python"
    else
        echo "python"
    fi
}

case "${1:-}" in
    local)
        MODE="${2:-offline}"
        
        PID=$(get_mcp_pid)
        if [ -n "$PID" ]; then
            print_info "MCP server is already running (PID: $PID)"
            exit 0
        fi
        
        print_info "Starting MCP server in $MODE mode..."
        cd "$PROJECT_ROOT"
        
        PYTHON=$(find_python)
        if [ "$MODE" = "remote" ]; then
            exec "$PYTHON" "$PROJECT_ROOT/mcp_server.py" --remote
        else
            exec "$PYTHON" "$PROJECT_ROOT/mcp_server.py"
        fi
        ;;
    
    stop)
        PID=$(get_mcp_pid)
        if [ -n "$PID" ]; then
            print_info "Stopping MCP server (PID: $PID)..."
            kill "$PID"
            print_success "MCP server stopped."
        else
            print_error "MCP server is not running."
        fi
        ;;
    
    status)
        PID=$(get_mcp_pid)
        if [ -n "$PID" ]; then
            print_success "MCP server is running (PID: $PID)"
        else
            print_error "MCP server is not running."
            echo "Run 'mcp local' to start it."
        fi
        ;;
    
    *)
        show_usage
        exit 1
        ;;
esac
